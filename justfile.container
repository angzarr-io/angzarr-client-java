# Java client library - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI container jobs

set shell := ["bash", "-c"]

ROOT := `git rev-parse --show-toplevel`

default:
    @just --list

proto:
    gradle :proto:generateProto

build:
    gradle build

test:
    gradle :client:test

coverage:
    gradle jacocoTestReport

publish:
    gradle publish

# Format check (google-java-format)
fmt:
    #!/usr/bin/env bash
    JAR="/tmp/google-java-format.jar"
    if [ ! -f "$JAR" ]; then
        curl -sL -o "$JAR" "https://github.com/google/google-java-format/releases/download/v1.25.2/google-java-format-1.25.2-all-deps.jar"
    fi
    find client/src -name "*.java" | xargs java -jar "$JAR" --dry-run --set-exit-if-changed

# Auto-format code
fmt-fix:
    #!/usr/bin/env bash
    JAR="/tmp/google-java-format.jar"
    if [ ! -f "$JAR" ]; then
        curl -sL -o "$JAR" "https://github.com/google/google-java-format/releases/download/v1.25.2/google-java-format-1.25.2-all-deps.jar"
    fi
    find client/src -name "*.java" | xargs java -jar "$JAR" --replace

# Publish to local Maven repository for testing
publish-local:
    gradle publishToMavenLocal
