# Java client library - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI container jobs

set shell := ["bash", "-c"]

# Note: do not add a `git rev-parse`-based ROOT here — the container user UID
# differs from the host user, so git refuses the repo as "dubious ownership".
# Inside the container the workspace is always /workspace.

default:
    @just --list

# Proto generation runs the gradle protobuf plugin directly. The plugin is the
# EXECUTOR; the trigger (mtime guard, lefthook, recipe deps) lives in the
# host-side justfile per project_proto_generation_model.
generate-proto-force:
    gradle --no-daemon :proto:generateProto

# Back-compat aliases.
generate-proto: generate-proto-force
proto: generate-proto-force

build: generate-proto-force
    gradle --no-daemon build

test: generate-proto-force
    gradle --no-daemon :client:test

coverage: generate-proto-force
    gradle --no-daemon jacocoTestReport

mutation-test: generate-proto-force
    gradle --no-daemon :client:pitest

publish: generate-proto-force
    gradle --no-daemon publish

# Format check (google-java-format)
fmt:
    #!/usr/bin/env bash
    JAR="/tmp/google-java-format.jar"
    if [ ! -f "$JAR" ]; then
        curl -sL -o "$JAR" "https://github.com/google/google-java-format/releases/download/v1.25.2/google-java-format-1.25.2-all-deps.jar"
    fi
    find client/src -name "*.java" | xargs java -jar "$JAR" --dry-run --set-exit-if-changed

# Auto-format code
fmt-fix:
    #!/usr/bin/env bash
    JAR="/tmp/google-java-format.jar"
    if [ ! -f "$JAR" ]; then
        curl -sL -o "$JAR" "https://github.com/google/google-java-format/releases/download/v1.25.2/google-java-format-1.25.2-all-deps.jar"
    fi
    find client/src -name "*.java" | xargs java -jar "$JAR" --replace

# Publish to local Maven repository for testing
publish-local: generate-proto-force
    gradle --no-daemon publishToMavenLocal
